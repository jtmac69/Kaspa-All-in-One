{
  "name": "kaspa-aio-tray",
  "version": "0.9.3",
  "description": "Kaspa AIO system tray controller",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux deb",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "test": "node --test src/*.test.js",
    "icons": "node scripts/create-placeholder-icons.js",
    "icons:icns": "bash scripts/create-icns.sh"
  },
  "dependencies": {
    "auto-launch": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "author": {
    "name": "Kaspa AIO Contributors",
    "email": "noreply@github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jtmac69/Kaspa-All-in-One.git"
  },
  "homepage": "https://github.com/jtmac69/Kaspa-All-in-One",
  "license": "MIT"
}
